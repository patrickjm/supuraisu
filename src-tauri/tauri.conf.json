{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Supuraisu",
  "version": "0.1.2",
  "identifier": "com.patrickmoriarty.supuraisu",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Supuraisu",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2NUM1MkJFRjQ4MEZDMTAKUldRUS9JRDB2bEpjeGg0d1dhQ0dGajhGWlc2bmdva1dBa00rbjRWRmZOeEdnY2ZUMFk1bzlmNU4K",
      "endpoints": [
        "https://github.com/patrickjm/supuraisu/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
